#!/usr/bin/env bash
set -euo pipefail

# Run this from your dev machine to set up Specto on a Dokku server.
# Usage: ./bin/dokku-setup

DOKKU_HOST="${DOKKU_HOST:-192.168.0.29}"
APP_NAME="specto"
DB_NAME="specto-db"
DOMAIN="specto.estifanos.cc"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="${1:-${SCRIPT_DIR}/.env.production}"

dokku_cmd() {
  ssh "dokku@${DOKKU_HOST}" "$@"
}

echo "==> Creating app: ${APP_NAME}"
dokku_cmd apps:create "$APP_NAME" || echo "    (app already exists)"

echo "==> Setting domain: ${DOMAIN}"
dokku_cmd domains:set "$APP_NAME" "$DOMAIN"

echo "==> Creating PostgreSQL database: ${DB_NAME}"
dokku_cmd postgres:create "$DB_NAME" || echo "    (database already exists)"

echo "==> Linking database to app"
dokku_cmd postgres:link "$DB_NAME" "$APP_NAME" || echo "    (already linked)"

echo "==> Setting required environment variables"
dokku_cmd config:set --no-restart "$APP_NAME" \
  ENCRYPTION_KEY="$(openssl rand -hex 32)" \
  SESSION_SECRET="$(openssl rand -base64 32)" \
  CSRF_KEY="$(openssl rand -base64 32 | head -c 32)" \
  PORT=5000 \
  BASE_URL="https://${DOMAIN}"

# Load additional env vars from file (skip comments and blank lines)
if [ -f "$ENV_FILE" ]; then
  echo "==> Loading env vars from ${ENV_FILE}"
  env_args=()
  while IFS= read -r line || [ -n "$line" ]; do
    # Skip comments and blank lines
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
    env_args+=("$line")
  done < "$ENV_FILE"

  if [ ${#env_args[@]} -gt 0 ]; then
    dokku_cmd config:set --no-restart "$APP_NAME" "${env_args[@]}"
    echo "    Set ${#env_args[@]} variable(s)"
  fi
else
  echo "==> No ${ENV_FILE} found, skipping optional env vars"
  echo "    Create one with KEY=value pairs (e.g. SPOTIFY_CLIENT_ID=abc123)"
fi

echo ""
echo "==> Done! Next steps:"
echo ""
echo "  1. Add git remote and deploy:"
echo "     git remote add dokku dokku@${DOKKU_HOST}:${APP_NAME}"
echo "     git push dokku main"
echo ""
echo "  2. Update OAuth redirect URIs to https://${DOMAIN}/auth/{provider}/callback"
echo ""
