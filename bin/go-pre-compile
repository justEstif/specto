#!/usr/bin/env bash
set -e

GOBIN="/tmp/gobin"
mkdir -p "$GOBIN"

echo "-----> Installing templ"
GOBIN="$GOBIN" go install github.com/a-h/templ/cmd/templ@latest

echo "-----> Installing sqlc"
GOBIN="$GOBIN" go install github.com/sqlc-dev/sqlc/cmd/sqlc@latest

echo "-----> Generating templ files"
"$GOBIN/templ" generate

echo "-----> Generating sqlc files"
"$GOBIN/sqlc" generate

echo "-----> Installing Tailwind CSS standalone CLI"
curl -sLo tailwindcss "https://github.com/tailwindlabs/tailwindcss/releases/latest/download/tailwindcss-linux-x64"
chmod +x tailwindcss

echo "-----> Downloading DaisyUI plugin"
curl -sLO "https://github.com/saadeghi/daisyui/releases/latest/download/daisyui.mjs"
curl -sLO "https://github.com/saadeghi/daisyui/releases/latest/download/daisyui-theme.mjs"

echo "-----> Building Tailwind CSS"
mkdir -p static/css
./tailwindcss -i styles/input.css -o static/css/tailwind.css --minify
