### Register a new user
# @name register
{{
  const timestamp = Date.now();
  exports.testEmail = `test_${timestamp}@example.com`;
  exports.testDisplayName = "Test User";
  exports.testPassword = "password123";
}}
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "{{testEmail}}",
  "display_name": "{{testDisplayName}}",
  "password": "{{testPassword}}"
}

?? status == 201
?? header content-type includes json
?? body data.email == {{testEmail}}
?? body data.display_name == {{testDisplayName}}

### Register - missing fields (expect 422)
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "test@example.com"
}

?? status == 422
?? body error.code == validation_error

### Register - short password (expect 422)
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "test2@example.com",
  "display_name": "Test 2",
  "password": "short"
}

?? status == 422
?? body error.code == validation_error

### Register - duplicate email (expect 409)
# @ref register
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "{{testEmail}}",
  "display_name": "{{testDisplayName}}",
  "password": "{{testPassword}}"
}

?? status == 409
?? body error.code == validation_error

### Login - wrong password (expect 401)
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "wrongpassword"
}

?? status == 401
?? body error.code == unauthorized

### Login - nonexistent user (expect 401)
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "nobody@example.com",
  "password": "password123"
}

?? status == 401
?? body error.code == unauthorized

### Login
# @ref register
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "{{testEmail}}",
  "password": "{{testPassword}}"
}

?? status == 200
?? header content-type includes json
?? body data.email == {{testEmail}}

### Logout
DELETE {{baseUrl}}/api/v1/session

?? status == 204
