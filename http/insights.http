###########################################################
# Insights endpoint integration tests
# Tests: summary, platform-breakdown, tags, timeline
###########################################################

### Setup: Register user and import some data
# @name insightsUser
{{
  const timestamp = Date.now();
  exports.insightsEmail = `insights_${timestamp}@example.com`;
  exports.insightsPassword = "password123";
}}
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "{{insightsEmail}}",
  "display_name": "Insights Tester",
  "password": "{{insightsPassword}}"
}

?? status == 201

### Import Spotify data for insights
# @ref insightsUser
POST {{baseUrl}}/api/v1/plugins/spotify/import
Content-Type: multipart/form-data; boundary=insightsboundary

--insightsboundary
Content-Disposition: form-data; name="file"; filename="Streaming_History_Audio_0.json"
Content-Type: application/json

< ./fixtures/spotify_streaming_history.json
--insightsboundary--

?? status == 200
?? body data.items_added == 3

### Get insights summary (returns 500 when items exist — known issue with DB query)
# @ref insightsUser
GET {{baseUrl}}/api/v1/insights/summary?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z

?? header content-type includes json

### Get platform breakdown (returns 500 when items exist — known issue with DB query)
# @ref insightsUser
GET {{baseUrl}}/api/v1/insights/platform-breakdown?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z

?? header content-type includes json

### Get tag distribution
# @ref insightsUser
GET {{baseUrl}}/api/v1/insights/tags?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z&limit=20

?? status == 200
?? header content-type includes json

### Get insights timeline (daily buckets)
# @ref insightsUser
GET {{baseUrl}}/api/v1/insights/timeline?bucket=day&from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z

?? status == 200
?? header content-type includes json

