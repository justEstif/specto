?? status == 200
?? header content-type includes json

### Get insights timeline (monthly buckets)
# @ref insightsUser
GET {{baseUrl}}/api/v1/insights/timeline?bucket=month&from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z

?? status == 200
?? header content-type includes json

### Invalid date range (expect 400)
# @ref insightsUser
GET {{baseUrl}}/api/v1/insights/summary?from=not-a-date

?? status == 400
?? body error.code == validation_error

